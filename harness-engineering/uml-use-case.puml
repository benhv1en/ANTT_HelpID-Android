@startuml
' UML Use-case Diagram for HelpID Android, website, backend auth API and serverless proxy.
left to right direction
skinparam defaultFontName "DejaVu Sans"
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #F8FAFC
  BorderColor #334155
}
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #475569
}
skinparam actor {
  BorderColor #1F2937
}

title HelpID - Sơ đồ UML Use-case đăng ký/đăng nhập và hồ sơ khẩn cấp

actor "Người dùng HelpID\n(Android)" as User
actor "Liên hệ khẩn cấp" as EmergencyContact
actor "Người phản hồi / cứu hộ\n(quét QR hoặc NFC)" as Responder
actor "Khách truy cập web" as WebVisitor
actor "Client gọi Gemini proxy" as GeminiClient
actor "Quản trị vận hành" as Operator

actor "Backend HelpID API\nASP.NET Core" as BackendApi <<external>>
actor "SQLite HelpIdDb" as SQLiteDb <<external>>
actor "Vercel Serverless API" as VercelApi <<external>>
actor "Firebase Auth / Firestore\nluồng cũ chuyển đổi" as FirebaseLegacy <<external>>
actor "Dịch vụ vị trí\nGoogle Play Services" as LocationService <<external>>
actor "Hệ thống SMS / Điện thoại" as Telephony <<external>>
actor "Danh bạ Android" as ContactsProvider <<external>>
actor "Thiết bị NFC" as NfcDevice <<external>>
actor "Gemini API" as GeminiApi <<external>>

rectangle "Ứng dụng Android HelpID" as AndroidApp {
  usecase "Đăng ký tài khoản" as UC_AndroidRegister
  usecase "Đăng nhập" as UC_AndroidLogin
  usecase "Khôi phục session\nkhi mở app" as UC_AndroidRestoreSession
  usecase "Refresh access token" as UC_AndroidRefreshToken
  usecase "Logout và xóa token local" as UC_AndroidLogout
  usecase "Xem ID / hồ sơ khẩn cấp\noffline-first" as UC_ViewEmergencyId
  usecase "Xem hồ sơ local cache\nkhi offline hoặc token lỗi" as UC_ViewLocalCache
  usecase "Chỉnh sửa hồ sơ y tế" as UC_EditProfile
  usecase "Chọn liên hệ từ danh bạ" as UC_PickContact
  usecase "Lưu hồ sơ cục bộ\nvào Room" as UC_SaveLocal
  usecase "Đồng bộ hồ sơ\nqua backend mới" as UC_SyncBackendProfile
  usecase "Lưu pending sync\nkhi offline hoặc lỗi" as UC_PendingSync
  usecase "Đổi ngôn ngữ app" as UC_ChangeLanguage
  usecase "Gọi số cấp cứu quốc gia" as UC_CallEmergency
  usecase "Gọi / SMS / sao chép\nliên hệ khẩn cấp" as UC_ContactActions
  usecase "Gửi SOS" as UC_SendSos
  usecase "Kiểm tra quyền\nSMS / vị trí / thông báo" as UC_CheckPermissions
  usecase "Lấy vị trí hiện tại" as UC_GetLocation
  usecase "Gửi SMS SOS\ntới liên hệ" as UC_SendSosSms
  usecase "Tạo link hồ sơ\ndự phòng cho SOS" as UC_SosFallbackLink
  usecase "Chia sẻ SOS dự phòng" as UC_ShareSosFallback
  usecase "Tự động gọi cấp cứu\nsau countdown" as UC_AutoEmergencyCall
  usecase "Hủy countdown / auto-call" as UC_CancelSosCountdown
  usecase "Cập nhật vị trí SOS định kỳ" as UC_SosFollowUp
  usecase "Hiển thị thông báo\nSOS thành công / thất bại" as UC_ShowNotification
  usecase "Tạo QR hồ sơ khẩn cấp" as UC_GenerateQr
  usecase "Bật NFC Tap-to-Assist" as UC_EnableNfc
  usecase "Chia sẻ / xuất PDF\nthông tin khẩn cấp" as UC_ShareExportProfile
}

rectangle "Website Helper ID" as WebApp {
  usecase "Xem trang marketing\nsản phẩm / giới thiệu / điều khoản" as UC_ViewMarketing
  usecase "Mở public emergency profile\n/e/:publicKey" as UC_OpenPublicProfile
  usecase "Gọi API public profile\nqua proxy hoặc backend" as UC_WebFetchPublicProfile
  usecase "Hiển thị lỗi link\nthiếu / hết hạn / revoke" as UC_WebPublicProfileError
  usecase "Mở deep link về Android app" as UC_OpenDeepLink
}

rectangle "Backend HelpID API\n(ASP.NET Core + EF Core SQLite)" as Backend {
  usecase "Đăng ký account\nPOST /api/v1/auth/register" as UC_ApiRegister
  usecase "Đăng nhập\nPOST /api/v1/auth/login" as UC_ApiLogin
  usecase "Refresh token\nPOST /api/v1/auth/refresh" as UC_ApiRefresh
  usecase "Logout / revoke token\nPOST /api/v1/auth/logout" as UC_ApiLogout
  usecase "Xem session hiện tại\nGET /api/v1/auth/me" as UC_ApiMe
  usecase "Hash password" as UC_HashPassword
  usecase "Cấp JWT access token" as UC_IssueAccessToken
  usecase "Rotate refresh token\nvà lưu token hash" as UC_RotateRefreshToken
  usecase "Enforce role / permission\nvà ownership" as UC_EnforceAuthorization
  usecase "Quản lý role / permission\ncode-first" as UC_RolePermission
  usecase "Lấy hồ sơ private\nGET /api/v1/profile" as UC_ApiGetProfile
  usecase "Cập nhật hồ sơ private\nPUT /api/v1/profile" as UC_ApiUpdateProfile
  usecase "Mint public profile link\nPOST /api/v1/emergency-links/mint" as UC_ApiMintLink
  usecase "Tạo hoặc tái sử dụng\npublic key HID-*" as UC_EnsurePublicKey
  usecase "Ký JWT public profile\n3 giờ" as UC_SignProfileJwt
  usecase "Lấy public profile\nGET /api/v1/public/profile" as UC_ApiGetPublicProfile
  usecase "Xác thực JWT public\nvà public key" as UC_VerifyProfileJwt
  usecase "Sanitize whitelist\nfield hồ sơ" as UC_SanitizeProfile
  usecase "Ghi audit event\nkhông chứa dữ liệu nhạy cảm" as UC_AuditEvent
  usecase "Validate request\nvà chặn SQL injection" as UC_ValidateAntiInjection
  usecase "Health check\nGET /health" as UC_Health
}

rectangle "Vercel Serverless API" as Serverless {
  usecase "Proxy public profile\n/api/profile -> backend" as UC_ProxyPublicProfile
  usecase "Legacy mint Firebase\nPOST /api/mint" as UC_LegacyMint
  usecase "Legacy profile Firebase\nGET /api/profile" as UC_LegacyProfile
  usecase "Proxy Gemini\nPOST /api/gemini" as UC_ProxyGemini
  usecase "Kiểm tra bearer token\nGemini proxy" as UC_CheckGeminiBearer
  usecase "Kiểm tra prompt\nvà timeout" as UC_ValidateGeminiPrompt
}

User -- UC_AndroidRegister
User -- UC_AndroidLogin
User -- UC_AndroidRestoreSession
User -- UC_AndroidLogout
User -- UC_ViewEmergencyId
User -- UC_EditProfile
User -- UC_ChangeLanguage
User -- UC_CallEmergency
User -- UC_ContactActions
User -- UC_SendSos
User -- UC_CancelSosCountdown
User -- UC_GenerateQr
User -- UC_EnableNfc
User -- UC_ShareExportProfile

EmergencyContact -- UC_ContactActions
EmergencyContact -- UC_SendSosSms
EmergencyContact -- UC_SosFollowUp

Responder -- UC_OpenPublicProfile
Responder -- UC_OpenDeepLink
WebVisitor -- UC_ViewMarketing
GeminiClient -- UC_ProxyGemini
Operator -- UC_Health

UC_AndroidRegister ..> UC_ApiRegister : <<include>>
UC_AndroidLogin ..> UC_ApiLogin : <<include>>
UC_AndroidRestoreSession ..> UC_AndroidRefreshToken : <<include>>
UC_AndroidRestoreSession ..> UC_ApiMe : <<include>>
UC_AndroidRefreshToken ..> UC_ApiRefresh : <<include>>
UC_AndroidLogout ..> UC_ApiLogout : <<include>>

UC_ViewEmergencyId ..> UC_ViewLocalCache : <<include>>
UC_ViewEmergencyId ..> UC_SyncBackendProfile : <<extend>>
UC_ViewLocalCache ..> UC_SaveLocal : <<include>>
UC_EditProfile ..> UC_SaveLocal : <<include>>
UC_EditProfile ..> UC_SyncBackendProfile : <<include>>
UC_SyncBackendProfile ..> UC_ApiGetProfile : <<include>>
UC_SyncBackendProfile ..> UC_ApiUpdateProfile : <<include>>
UC_PickContact ..> UC_EditProfile : <<extend>>
UC_PendingSync ..> UC_SyncBackendProfile : <<extend>>

UC_SendSos ..> UC_CheckPermissions : <<include>>
UC_SendSos ..> UC_GetLocation : <<include>>
UC_SendSos ..> UC_SendSosSms : <<include>>
UC_SendSos ..> UC_SosFollowUp : <<include>>
UC_SendSos ..> UC_ShowNotification : <<include>>
UC_SosFallbackLink ..> UC_SendSos : <<extend>>
UC_ShareSosFallback ..> UC_SendSos : <<extend>>
UC_AutoEmergencyCall ..> UC_SendSos : <<extend>>
UC_CancelSosCountdown ..> UC_SendSos : <<extend>>

UC_SosFallbackLink ..> UC_ApiMintLink : <<include>>
UC_GenerateQr ..> UC_ApiMintLink : <<include>>
UC_EnableNfc ..> UC_ApiMintLink : <<include>>

UC_OpenPublicProfile ..> UC_WebFetchPublicProfile : <<include>>
UC_WebFetchPublicProfile ..> UC_ProxyPublicProfile : <<extend>>
UC_WebFetchPublicProfile ..> UC_ApiGetPublicProfile : <<include>>
UC_WebPublicProfileError ..> UC_OpenPublicProfile : <<extend>>
UC_OpenDeepLink ..> UC_OpenPublicProfile : <<extend>>

UC_ApiRegister ..> UC_HashPassword : <<include>>
UC_ApiRegister ..> UC_IssueAccessToken : <<include>>
UC_ApiRegister ..> UC_RotateRefreshToken : <<include>>
UC_ApiRegister ..> UC_RolePermission : <<include>>
UC_ApiRegister ..> UC_AuditEvent : <<include>>
UC_ApiRegister ..> UC_ValidateAntiInjection : <<include>>
UC_ApiLogin ..> UC_HashPassword : <<include>>
UC_ApiLogin ..> UC_IssueAccessToken : <<include>>
UC_ApiLogin ..> UC_RotateRefreshToken : <<include>>
UC_ApiLogin ..> UC_AuditEvent : <<include>>
UC_ApiLogin ..> UC_ValidateAntiInjection : <<include>>
UC_ApiRefresh ..> UC_IssueAccessToken : <<include>>
UC_ApiRefresh ..> UC_RotateRefreshToken : <<include>>
UC_ApiLogout ..> UC_AuditEvent : <<include>>
UC_ApiMe ..> UC_EnforceAuthorization : <<include>>
UC_ApiGetProfile ..> UC_EnforceAuthorization : <<include>>
UC_ApiUpdateProfile ..> UC_EnforceAuthorization : <<include>>
UC_ApiUpdateProfile ..> UC_ValidateAntiInjection : <<include>>
UC_ApiMintLink ..> UC_EnforceAuthorization : <<include>>
UC_ApiMintLink ..> UC_EnsurePublicKey : <<include>>
UC_ApiMintLink ..> UC_SignProfileJwt : <<include>>
UC_ApiGetPublicProfile ..> UC_VerifyProfileJwt : <<include>>
UC_ApiGetPublicProfile ..> UC_SanitizeProfile : <<include>>
UC_ApiGetPublicProfile ..> UC_ValidateAntiInjection : <<include>>
UC_ProxyPublicProfile ..> UC_ApiGetPublicProfile : <<include>>
UC_ProxyGemini ..> UC_ValidateGeminiPrompt : <<include>>
UC_CheckGeminiBearer ..> UC_ProxyGemini : <<extend>>
UC_LegacyMint ..> UC_LegacyProfile : <<extend>>

BackendApi -- UC_ApiRegister
BackendApi -- UC_ApiLogin
BackendApi -- UC_ApiRefresh
BackendApi -- UC_ApiLogout
BackendApi -- UC_ApiGetProfile
BackendApi -- UC_ApiUpdateProfile
BackendApi -- UC_ApiMintLink
BackendApi -- UC_ApiGetPublicProfile
SQLiteDb -- UC_ApiRegister
SQLiteDb -- UC_RotateRefreshToken
SQLiteDb -- UC_RolePermission
SQLiteDb -- UC_ApiGetProfile
SQLiteDb -- UC_ApiUpdateProfile
SQLiteDb -- UC_EnsurePublicKey
SQLiteDb -- UC_AuditEvent
VercelApi -- UC_ProxyPublicProfile
VercelApi -- UC_LegacyMint
VercelApi -- UC_LegacyProfile
FirebaseLegacy -- UC_LegacyMint
FirebaseLegacy -- UC_LegacyProfile
LocationService -- UC_GetLocation
LocationService -- UC_SosFollowUp
Telephony -- UC_CallEmergency
Telephony -- UC_ContactActions
Telephony -- UC_SendSosSms
Telephony -- UC_AutoEmergencyCall
Telephony -- UC_SosFollowUp
ContactsProvider -- UC_PickContact
NfcDevice -- UC_EnableNfc
GeminiApi -- UC_ProxyGemini

note right of UC_ViewLocalCache
  Auth/backend lỗi không được chặn
  hồ sơ đã cache trong tình huống khẩn cấp.
end note

note bottom of Backend
  Backend lấy user id từ access JWT,
  không tin userId client gửi. Public profile
  chỉ trả whitelist field và không cache.
end note

note bottom of UC_ValidateAntiInjection
  Dùng EF Core LINQ/parameterized query,
  không ghép chuỗi SQL từ input người dùng.
end note
@enduml
