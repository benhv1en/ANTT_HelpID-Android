<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Allow HTTP cleartext to the Android emulator's host loopback (10.0.2.2)
        so the debug build can reach a local backend at http://10.0.2.2:5080.
        All other traffic is HTTPS-only via the base config.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
