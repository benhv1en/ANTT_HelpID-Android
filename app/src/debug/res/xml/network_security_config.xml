<?xml version="1.0" encoding="utf-8"?>
<!--
    DEBUG BUILD ONLY — overrides main/res/xml/network_security_config.xml.
    Allows cleartext HTTP to any host so the app can reach a local backend
    (http://10.0.2.2:5080 on emulator, http://192.168.x.x:5080 on real device).
    Production builds use the main config (HTTPS-only).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
</network-security-config>
