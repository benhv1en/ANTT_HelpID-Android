# Copy this file to backend/.env.local and fill in real values.
# backend/.env.local is gitignored — never commit actual secrets.

# JWT signing keys: minimum 32 bytes each, use a random string in production.
HELPID_AUTH_JWT_SIGNING_KEY="dev-auth-signing-key-32-byte-minimum-change-me"
HELPID_PROFILE_JWT_SIGNING_KEY="dev-profile-signing-key-32-byte-minimum-change-me"

# URL of the public web frontend (used in public profile link responses).
PublicWeb__BaseUrl="http://localhost:5173"

# ConnectionStrings__HelpIdDb is set automatically by run-backend.sh to an
# absolute path (backend/HelpId.Api/App_Data/helpid-dev.db). Only set this
# here if you want to point to a different database file.
# ConnectionStrings__HelpIdDb="Data Source=/absolute/path/to/helpid.db"

# Optional: override JWT issuer/audience if needed.
# AuthJwt__Issuer="https://helpid.local"
# AuthJwt__Audience="helpid-android"
