{
  "ConnectionStrings": {
    "HelpIdDb": "Data Source=App_Data/helpid-dev.db"
  },
  "AuthJwt": {
    "Issuer": "HelpId.Api",
    "Audience": "HelpId.Android",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30,
    "SigningKeyEnvironmentVariable": "HELPID_AUTH_JWT_SIGNING_KEY",
    "LockoutFailedAttempts": 5,
    "LockoutMinutes": 15,
    "PasswordMinLength": 8,
    "PasswordMaxLength": 128
  },
  "ProfileJwt": {
    "ExpiresInHours": 3
  },
  "PublicWeb": {
    "BaseUrl": "https://helper-id.vercel.app"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
